generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CLIENT
  SUB_ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentMethod {
  PIX
  CASH
  CARD
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model User {
  id                       String    @id @default(uuid())
  name                     String
  email                    String    @unique
  username                 String?   @unique
  phone                    String?
  password                 String
  role                     Role      @default(CLIENT)
  managedBarberId          String?   @map("managed_barber_id")
  passwordResetTokenHash   String?   @map("password_reset_token_hash")
  passwordResetExpiresAt   DateTime? @map("password_reset_expires_at")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  managedBarber     Barber?            @relation(fields: [managedBarberId], references: [id], onDelete: SetNull)
  appointments      Appointment[]
  pushSubscriptions PushSubscription[]

  @@index([managedBarberId])
  @@map("users")
}

model Barber {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  avatarUrl String?  @map("avatar_url")
  bio       String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  subAdminUsers  User[]
  appointments   Appointment[]
  barberServices BarberService[]
  workingHours   WorkingHour[]
  stockItems     StockItem[]

  @@map("barbers")
}

model StockItem {
  id          String   @id @default(uuid())
  barberId    String   @map("barber_id")
  name        String
  description String?
  quantity    Int      @default(0)
  unit        String   @default("un")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@index([barberId])
  @@map("stock_items")
}

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  duration    Int
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  appointments   Appointment[]
  barberServices BarberService[]

  @@map("services")
}

model BarberService {
  barberId  String @map("barber_id")
  serviceId String @map("service_id")

  barber  Barber  @relation(fields: [barberId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([barberId, serviceId])
  @@map("barber_services")
}

model WorkingHour {
  id        String @id @default(uuid())
  barberId  String @map("barber_id")
  dayOfWeek Int    @map("day_of_week")
  startTime String @map("start_time")
  endTime   String @map("end_time")

  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([barberId, dayOfWeek])
  @@map("working_hours")
}

model Appointment {
  id        String            @id @default(uuid())
  userId    String            @map("user_id")
  barberId  String            @map("barber_id")
  serviceId String            @map("service_id")
  dateTime  DateTime          @map("date_time")
  endTime   DateTime          @map("end_time")
  status    AppointmentStatus @default(PENDING)
  notes     String?
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id])
  barber  Barber  @relation(fields: [barberId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])
  payment Payment?

  @@map("appointments")
}

model Payment {
  id            String        @id @default(uuid())
  appointmentId String        @unique @map("appointment_id")
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod @default(PIX)
  status        PaymentStatus @default(PENDING)
  pixCode       String?       @map("pix_code")
  pixQrCode     String?       @map("pix_qr_code") @db.Text
  externalId    String?       @map("external_id")
  paidAt        DateTime?     @map("paid_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}
