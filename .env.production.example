# =============================================================
# BACKEND — Cole estas variáveis no painel do Railway
# (Settings → Variables do serviço barbearia_api)
# =============================================================

# Banco de dados — Railway preenche automaticamente se você
# adicionar um plugin PostgreSQL ao projeto:
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public

# JWT — gere com: openssl rand -hex 64
JWT_SECRET=TROQUE_POR_64_BYTES_ALEATORIOS
JWT_REFRESH_SECRET=TROQUE_POR_OUTROS_64_BYTES_ALEATORIOS

# Porta interna (Railway injeta $PORT automaticamente; deixe 3335 ou apague)
PORT=3335

# URLs de produção — use a URL pública gerada pelo Railway para o backend
CORS_ORIGIN=https://SEU-FRONTEND.vercel.app
FRONTEND_URL=https://SEU-FRONTEND.vercel.app

# Cookies
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# Push Notifications VAPID
# Gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=SUA_CHAVE_PUBLICA_VAPID
VAPID_PRIVATE_KEY=SUA_CHAVE_PRIVADA_VAPID
VAPID_EMAIL=seuemail@exemplo.com

# =============================================================
# FRONTEND — Cole estas variáveis no painel da Vercel
# (Project → Settings → Environment Variables)
# =============================================================

# URL pública do backend no Railway (ex: https://barbearia-api.up.railway.app/api)
NEXT_PUBLIC_API_URL=https://SEU-BACKEND.up.railway.app/api

# A mesma VAPID_PUBLIC_KEY de cima
NEXT_PUBLIC_VAPID_PUBLIC_KEY=SUA_CHAVE_PUBLICA_VAPID
